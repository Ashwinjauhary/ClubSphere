# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Supabase Configuratio
# Get these from: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Groq API Keys - Events Service
GROQ_EVENTS_KEY_1=your_groq_api_key_1
GROQ_EVENTS_KEY_2=your_groq_api_key_2
GROQ_EVENTS_KEY_3=your_groq_api_key_3

# Groq API Keys - Reports Service
GROQ_REPORTS_KEY_1=your_groq_api_key_4
GROQ_REPORTS_KEY_2=your_groq_api_key_5
GROQ_REPORTS_KEY_3=your_groq_api_key_6

# Groq API Keys - Forms Service
GROQ_FORMS_KEY_1=your_groq_api_key_7
GROQ_FORMS_KEY_2=your_groq_api_key_8
GROQ_FORMS_KEY_3=your_groq_api_key_9

# Groq API Keys - Daily Quiz Service
GROQ_QUIZ_KEY_1=your_groq_api_key_10
GROQ_QUIZ_KEY_2=your_groq_api_key_11
GROQ_QUIZ_KEY_3=your_groq_api_key_12
